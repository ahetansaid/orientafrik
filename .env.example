# =====================================================================
# ORIENTAFRIK — Variables d'environnement (copier vers .env.local)
# =====================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé service_role : SERVEUR UNIQUEMENT (webhooks, jobs admin). Ne jamais exposer au client.
SUPABASE_SERVICE_ROLE_KEY=
# Connexion Postgres directe (migrations / psql).
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Fedapay (mobile money MTN/Moov) ---
FEDAPAY_SECRET_KEY=
FEDAPAY_PUBLIC_KEY=
FEDAPAY_WEBHOOK_SECRET=

# --- Email transactionnel (Resend) ---
RESEND_API_KEY=

# --- Observabilité ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Divers ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
TZ=Africa/Porto-Novo
